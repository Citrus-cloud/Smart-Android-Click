<!-- Permissions / accessibility (Step 61) -->
<string name="permissions">Permissions</string>
<string name="btn_permissions">Permissions</string>
<string name="permissions_intro">Real input is still disabled. These switches only let the app *display* a system overlay marker and *see* whether the Accessibility service is enabled. They do not enable real taps — SafetyGate keeps real input blocked.</string>
<string name="permission_overlay">Display over other apps (system overlay)</string>
<string name="permission_overlay_description">Lets the app show a draggable marker on top of other apps. Used for preview only in this step.</string>
<string name="permission_accessibility">Accessibility service</string>
<string name="permission_accessibility_description">Lets the system bind the (currently empty) ClickFlow accessibility service. No events are processed; no taps are dispatched.</string>
<string name="permission_granted">Granted</string>
<string name="permission_not_granted">Not granted</string>
<string name="permission_status_unknown">Unknown</string>
<string name="open_overlay_settings">Open overlay settings</string>
<string name="open_accessibility_settings">Open accessibility settings</string>
<string name="refresh_permissions">Refresh status</string>
<string name="permissions_safety_note">Granting these permissions does NOT enable real taps. canRunRealTap() stays false.</string>
<string name="accessibility_service_label">ClickFlow (no automation)</string>
<string name="accessibility_service_summary">Declared for permission flow only. Performs no automation.</string>
<string name="accessibility_service_description">ClickFlow declares an accessibility service so you can practice enabling and disabling it. The service is empty: it subscribes to no events, reads no window content, and dispatches no taps. Real input remains hard-disabled by SafetyGate.</string>
<string name="floating_marker">Floating marker</string>
<string name="floating_marker_preview">Floating marker (preview only)</string>
<string name="floating_marker_description">When overlay permission is granted, ClickFlow can show a draggable circular marker on top of other apps. It is purely visual — it never taps anything.</string>
<string name="floating_marker_show">Show floating marker</string>
<string name="floating_marker_hide">Hide floating marker</string>
<string name="floating_marker_not_available">Grant overlay permission to enable the floating marker preview.</string>
<string name="floating_marker_simulation_only">Floating marker is a visual preview only. It does not perform real taps.</string>
